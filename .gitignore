# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Android Keystore Files (NEVER commit these!)
*.jks
*.keystore
keystore.properties
upload-keystore.jks

# iOS Build Files
ios/App/build/
ios/App/DerivedData/

# Android Build Files
android/app/build/
android/build/

# Capacitor 네이티브 프로젝트는 커밋 권장 (Windows ↔ Mac 이동 시 재생성·설정 누락 방지)
# 빌드 산출물·Pods 등은 각 플랫폼 .gitignore 및 위쪽 /out/, build/ 규칙으로 제외됨
